package operadores_print_scanner;

import java.util.Scanner;

public class exercicio4 {
    public void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int numFunc;
        float horasTrab, salario, valorHora;

        System.out.println("Digite seu id: ");
        numFunc = sc.nextInt();

        System.out.println("Digite a quantidade de horas trabalhadas: ");
        horasTrab = sc.nextFloat();

        System.out.println("Digite o valor que recebe por hora trabalhada: ");
        valorHora= sc.nextFloat();

        salario = horasTrab * valorHora;

        System.out.printf("Id funcionario: %d%nSalario: U$ %.2f", numFunc, salario);
        sc.close();
    }
}
